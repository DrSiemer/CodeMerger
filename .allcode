                  "name": "LLM Context Operations",
                  "description": "Specialized logic for bundling code, checking security, and applying AI-generated modifications.",
                  "files": [
                    {
                      "path": "src/core/merger.py",
                      "description": "Bundles selected files into the application's unique machine-parseable Markdown format. It manages the injection of mode-specific system instructions like 'Fast Apply' vs 'Full File'."
                    },
                    {
                      "path": "src/core/prompts.py",
                      "description": "The prompt engineering hub, containing the large prose blocks that dictate LLM stylistic guidelines and project generation constraints. It keeps logic and instruction text separate for easier maintenance."
                    },
                    {
                      "path": "src/core/secret_scanner.py",
                      "description": "A security auditing service that uses high-entropy detection to find API keys and credentials in code selections. It provides the metadata for the pre-copy warning dialogs."
                    },
                    {
                      "path": "src/core/replacer.py",
                      "description": "A sophisticated fuzzy matching engine capable of applying code patches even when line numbers or indentation vary from the model's reference. It uses multi-strategy matching to ensure reliable surgical updates."
                    },
                    {
                      "path": "src/core/change_applier.py",
                      "description": "The top-level parser for LLM responses, extracting file blocks and XML tags from Markdown. It coordinates the actual filesystem writes and standardizes all content to LF to prevent phantom diffs."
                    },
                    {
                      "path": "src/core/highlighter.py",
                      "description": "Leverages the Pygments library to generate the syntax-highlighted HTML used in the response review window. It calculates line-level differences using the standard library sequence matcher."
                    }
                  ],
