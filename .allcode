            {
              "name": "Logic Engine",
              "description": "The Python backend managing file systems, LLM interactions, and multi-window state synchronization.",
              "domain": "backend",
              "children": [
                {
                  "name": "Core Orchestration",
                  "description": "Foundational modules handling application entry, global state, and system utilities.",
                  "files": [
                    {
                      "path": "run_webview.py",
                      "description": "The main bootstrapper that configures Win32 DPI awareness and registers MIME types for ES modules. It initializes the API bridge and starts the PyWebView event loop."
                    },
                    {
                      "path": "src/app_state.py",
                      "description": "The central repository for persistent application settings and cross-window coordination. It implements a non-destructive reconciliation strategy to merge configurations from concurrent instances."
                    },
                    {
                      "path": "src/constants.py",
                      "description": "Defines global magic numbers, color palettes, and performance thresholds. Crucially, it hosts the marker fragments used to avoid recursive self-parsing errors during code bundling."
                    },
                    {
                      "path": "src/core/paths.py",
                      "description": "Handles OS-specific path resolution for bundled assets and persistent user data. It distinguishes between the immutable install directory and the writable %APPDATA% config root."
                    },
                    {
                      "path": "src/core/registry.py",
                      "description": "Interfaces with the Windows Registry to manage system-level preferences like automatic update toggles. It provides fallbacks between HKCU and HKLM scopes."
                    },
                    {
                      "path": "src/core/utils.py",
                      "description": "A collection of critical logic utilities, including the Named Mutex single-instance detector and the Tiktoken context window calculator. It hosts the atomic file-writing logic used to prevent config corruption."
                    }
                  ],
                  "id": 8,
                  "domain": "backend",
                  "color": "#0078D4",
                  "weight": 6,
                  "layout": {
                    "x": 0,
                    "y": 36.84210526315789,
                    "w": 25,
                    "h": 63.15789473684211
                  }
                },
                {
                  "name": "File & Data Intelligence",
                  "description": "Services responsible for scanning codebases and managing project-specific configurations.",
                  "files": [
                    {
                      "path": "src/core/project_manager.py",
                      "description": "The high-level controller for project lifecycle management, responsible for initializing new .allcode profiles and maintaining the in-memory disk inventory. It provides the concurrency locks required to synchronize the monitor thread and user API requests."
                    },
                    {
                      "path": "src/core/project_config.py",
                      "description": "The logic wrapper for the .allcode file, handling profile creation, file selection state, and per-file token counting. It includes defensive loading checks to ignore collision-based empty files."
                    },
                    {
                      "path": "src/core/file_scanner.py",
                      "description": "An optimized disk walker that extracts project file lists while simultaneously discovering and parsing .gitignore patterns. It is designed to move expensive IO operations out of the UI rendering loop."
                    },
                    {
                      "path": "src/core/file_tree_builder.py",
                      "description": "The transformation engine that converts flat file lists into hierarchical Trie data for the frontend. It features an inventory-first mode for instant UI results on codebases with 10k+ files."
                    },
                    {
                      "path": "src/core/file_monitor_thread.py",
                      "description": "A daemon thread that performs background filesystem checks to alert users of new or deleted files. It uses adaptive throttling based on scan duration to minimize the app's CPU footprint."
                    },
                    {
                      "path": "src/core/logger.py",
                      "description": "Configures a sophisticated dual-logging system using the Rich library for console diagnostics and rotating file handlers for persistent logs. It includes dummy streams to prevent crashes in windowed mode."
